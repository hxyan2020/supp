  "terms": {
    "title": "Terms of Use",
    "updated": "Last updated: July 2026",
    "back": "Back",
    "sections": [
      {
        "heading": "Sharing experience ideas",
        "body": "Supp lets you publish ideas for real-world experiences. By submitting content, you confirm that you have the right to share it and that it is offered in good faith for others to try safely and respectfully."
      },
      {
        "heading": "Community standards",
        "body": "Do not post illegal activity, hate, harassment, sexual content involving minors, or instructions that could cause serious harm. Ideas that promote scams, discrimination, or invasion of privacy may be removed without notice."
      },
      {
        "heading": "Safety & responsibility",
        "body": "You are responsible for your own actions when trying or hosting an experience. Follow local laws, respect private property, and never pressure others into something they are uncomfortable with. Supp does not guarantee the accuracy or safety of user-submitted ideas."
      },
      {
        "heading": "Moderation",
        "body": "We may screen, edit, hide, or remove ideas that break these terms or our community guidelines. Repeated violations may lead to account restrictions."
      },
      {
        "heading": "Contact",
        "body": "If you have questions about these terms or need to report content, reach out through the support options in the Me section of the app."
      }
    ]
